<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppWebNetOpenIA_v1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppWebNetOpenIA_v1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container">
                <strong>
                    <a class="navbar-brand rounded" style="background-color: orangered; margin-left: auto;"
                       asp-area="" asp-controller="OpenAI" asp-action="Index">
                        <span style="margin: 5px 15px; display: inline-block; font-size: 25px">TecnofertaAI</span>
                    </a>

                </strong>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item me-2">
                            <form asp-controller="OpenAI" asp-action="ConsultarVentas" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-secondary">
                                    <b>Consultar Ventas</b>
                                </button>
                            </form>
                        </li>
                        <li class="nav-item me-2">
                            <form asp-controller="OpenAI" asp-action="ConsultarCompras" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-secondary">
                                    <b>Consultar Compras</b>
                                </button>
                            </form>
@*                             <strong><a class="nav-link text-light bg-secondary rounded px-2" asp-area="" asp-controller="OpenAI" asp-action="ConsultarCompras">Consultar Compras</a></strong>
 *@                        </li>
                        <li class="nav-item">
                            <form asp-controller="OpenAI" asp-action="GenerarChats" method="post" class="d-inline">
                                @if (ViewBag.MostrarBoton == true)
                                 { 
                                    <button type="submit" class="btn btn-outline-secondary" >
                                    <b>Enviar Mensaje</b>
                                    </button> 
                                 }
                            </form>
                        </li>
                        <li class="nav-item me-2">
                            <form asp-controller="OpenAI" asp-action="ConsultarStock" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-secondary">
                                    <b>Consultar Stock</b>
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-light bg-dark">
        <div class="container">
            &copy; 2025 - AppWebNetOpenIA_v1 - <a asp-area="" asp-controller="OpenAI" asp-action="Privacy">Inicio</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://kit.fontawesome.com/YOUR_KIT_CODE.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
